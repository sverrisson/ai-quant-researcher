# --- Anthropic API ---
# Required for examples 06-08 and `python -m ai_quant_lab.run`.
# Examples 01-05 work without this key.
ANTHROPIC_API_KEY=sk-ant-...

# Model used by all agents. Default is the latest Sonnet — fast, cheap, strong reasoning.
# Override to claude-opus-4-7 for harder synthesis tasks.
AI_QUANT_LAB_MODEL=claude-sonnet-4-6

# --- Research loop budget ---
# Hard cap on Claude calls per `run`. Prevents runaway spending.
AI_QUANT_LAB_MAX_LLM_CALLS=200

# Maximum strategies kept by the gate (deflated Sharpe survivors).
AI_QUANT_LAB_TARGET_SURVIVORS=3

# --- Statistical gates ---
# Deflated Sharpe Ratio significance threshold. Strategies with DSR p-value above this are killed.
# 0.05 = standard 5% level. Tighter (0.01) = harder gate.
AI_QUANT_LAB_DSR_PVALUE_MAX=0.05

# Maximum allowed pairwise correlation between accepted strategies.
# Above this, the new strategy is rejected as redundant.
AI_QUANT_LAB_MAX_CORRELATION=0.6

# --- Backtest defaults ---
# Realistic round-trip transaction cost in basis points.
AI_QUANT_LAB_COST_BPS=8.0

# Annualization factor (252 for daily equities, 365 for crypto, etc.).
AI_QUANT_LAB_ANNUALIZATION=252

# --- Storage ---
# SQLite path for research memory. Tracks every hypothesis ever tried (for DSR n_trials).
AI_QUANT_LAB_MEMORY_DB=./memory.db
